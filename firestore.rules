rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ユーザー情報: 本人だけ読み書き可
    match /users/{userId} {
      allow read, write: if request.auth == null
        || request.auth.uid == userId;
      // ※ LIFFはFirebase Authと連携しない構成のため、
      //   本番ではバックエンドAPIを挟んでサーバー側で書き込むことを推奨
    }

    // プレイ回数: 本人だけ
    match /plays/{docId} {
      allow read, write: if true; // 開発中は全許可、本番前に絞ること
    }

    // ポイント履歴: 書き込みは誰でも可（本番はAPI経由に変更）
    match /pointLog/{docId} {
      allow read: if true;
      allow write: if true;
    }

    // 交換履歴
    match /exchanges/{docId} {
      allow read, write: if true;
    }

    // お知らせ（全員読み取り可・書き込みも許可）
    match /news/{docId} {
      allow read, write: if true;
    }

    // フレンド関係
    match /friends/{docId} {
      allow read, write: if true;
    }

    // 対戦
    match /battles/{docId} {
      allow read, write: if true;
    }
  }
}
